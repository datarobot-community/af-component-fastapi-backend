import logging
from contextlib import asynccontextmanager
from dataclasses import dataclass
from typing import AsyncGenerator
from app.config import Config
{% endfilter %}

logger = logging.getLogger(__name__)

@dataclass
class Deps:
{% filter sortlines %}{% filter subcomponent_include("deps/fields.jinja", indent=4) %}
config: Config
{% endfilter %}{% endfilter %}

{% filter subcomponent_include("deps/helpers.jinja") %}{%endfilter%}

@asynccontextmanager
async def create_deps(
    config: Config, deps: Deps | None = None
) -> AsyncGenerator[Deps, None]:
    """
    Create a dependency context for the application (with both startup and shutdown routines).
    Dependencies are basically singletons that are shared on the application server level.
    """
    if deps:
        # this is used for testing when dependencies are given for us
        yield deps
        return

{% filter subcomponent_include("deps/create_deps_pre_startup.jinja", indent=4) %}
# startup routine
{% endfilter %}
{% filter subcomponent_include("deps/create_deps_post_startup.jinja", subcomponents, indent=4) %}{% endfilter %}    

    yield Deps(
{% filter subcomponent_include("deps/create_deps_deps_fields.jinja", indent=8) %}
        config=config,
{% endfilter %}    )

{% filter subcomponent_include("deps/create_deps_shutdown.jinja", indent=4) %}
# shutdown routine
{% endfilter %}
{% endfilter %}{% endfilter %}