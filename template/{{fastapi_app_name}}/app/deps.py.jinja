@asynccontextmanager
async def create_deps(
    config: Config, deps: Deps | None = None
) -> AsyncGenerator[Deps, None]:
    """
    Create a dependency context for the application (with both startup and shutdown routines).
    Dependencies are basically singletons that are shared on the application server level.
    """
    if deps:
        # this is used for testing when dependencies are given for us
        yield deps
        return

    # startup routine
{% filter subcomponent_include("deps/create_deps_prestartup.jinja", subcomponents, indent=4) %}{% endfilter %}
{% filter subcomponent_include("deps/create_deps_poststartup.jinja", subcomponents, indent=4) %}{% endfilter %}    


    yield Deps(
{% filter subcomponent_include("deps/create_deps_deps_fields.jinja", subcomponents, indent=8) %}
        config=config,
{% endfilter %}    )

    # shutdown routine
{% filter subcomponent_include("deps/create_deps_shutdown.jinja", subcomponents, indent=4) %}{% endfilter %}

